{
  "name": "library-management-system-root",
  "version": "1.0.0",
  "description": "MERN Stack Library Management System",
  "scripts": {
    "install-all": "npm install && npm install --prefix backend && npm install --prefix frontend --legacy-peer-deps",
    "backend": "npm run dev --prefix backend",
    "frontend": "npm run dev --prefix frontend",
    "seed": "npm run seed --prefix backend",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
